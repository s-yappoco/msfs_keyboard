{
    "manufacturer": "yamapy",
    "keyboard_name": "msfs_keyboard",
    "maintainer": "yamapy",
    "bootloader": "rp2040",
    "diode_direction": "ROW2COL",
    "features": {
		"rgblight": true,
        "bootmagic": true,
        "extrakey": false,
        "mousekey": false,
		"joystick": false,
		"encoder": true,
        "nkro": false
    },
    "dynamic_keymap": {
        "layer_count": 16
    },
    "encoder": {
        "rotary": [
            { "pin_a": "GP9", "pin_b": "GP10", "resolution": 4 },
            { "pin_a": "GP11", "pin_b": "GP12", "resolution": 4 },
            { "pin_a": "GP13", "pin_b": "GP14", "resolution": 4 },
            { "pin_a": "GP15", "pin_b": "GP16", "resolution": 4 },
            { "pin_a": "GP17", "pin_b": "GP18", "resolution": 4 },
            { "pin_a": "GP19", "pin_b": "GP20", "resolution": 4 },
            { "pin_a": "GP21", "pin_b": "GP22", "resolution": 4 }
        ]
    },	
    "matrix_pins": {
        "cols": ["GP4", "GP5", "GP6", "GP7", "GP8"],
        "rows": ["GP0", "GP1", "GP2", "GP3", "GP0", "GP1", "GP2", "GP3"]
    },
    "processor": "RP2040",
    "url": "",
    "usb": {
        "device_version": "1.0.0",
        "pid": "0x0000",
        "vid": "0xFEED"
    },
	"ws2812": {
        "driver": "vendor",
        "pin": "GP23"
    },
	
	"rgblight": {
        "led_count": 5,
        "animations": {
            "breathing": true,
            "rainbow_mood": true,
            "rainbow_swirl": true,
            "snake": true,
            "knight": true,
            "christmas": true,
            "static_gradient": true,
            "rgb_test": true,
            "alternating": true,
            "twinkle": true
        },
        "layers":{
            "enabled": true,
            "max": 32,
        },
        "led_map": [0, 1, 2, 3, 4],
        "max_brightness": 255,
        "split": false
    },

    "layouts": {
		"LAYOUT": {
            "layout": [
			
				{"label": "SW1",     "matrix": [0, 0], "x": 0, "y": 0},
				{"label": "SW2",     "matrix": [1, 0], "x": 0, "y": 1},
				{"label": "SW3",     "matrix": [2, 0], "x": 0, "y": 2},
				{"label": "SW4",     "matrix": [3, 0], "x": 0, "y": 3},
				{"label": "SW5",     "matrix": [4, 0], "x": 0, "y": 4},
				{"label": "SW6",     "matrix": [5, 0], "x": 0, "y": 5},

				{"label": "SW8",     "matrix": [0, 1], "x": 1, "y": 0},
				{"label": "SW9",     "matrix": [1, 1], "x": 1, "y": 1},
				{"label": "SW10",    "matrix": [2, 1], "x": 1, "y": 2},
				{"label": "SW11",    "matrix": [3, 1], "x": 1, "y": 3},
				{"label": "SW12",    "matrix": [4, 1], "x": 1, "y": 4},
				{"label": "SW13",    "matrix": [5, 1], "x": 1, "y": 5},
				
				{"label": "SW7",     "matrix": [6, 0], "x": 0.5, "y": 6},	

				{"label": "RSW1S1",  "matrix": [0, 2], "x": 3, "y": 0},
				{"label": "RSW2S1",  "matrix": [1, 2], "x": 3, "y": 2},				
