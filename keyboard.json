				{"label": "JSTKUP",  "matrix": [7, 0], "x": 4, "y": 1},
				{"label": "JSTKDN",  "matrix": [1, 3], "x": 4, "y": 2},
				{"label": "JSTKR",   "matrix": [2, 3], "x": 4, "y": 3},
				{"label": "JSTKL",   "matrix": [3, 3], "x": 4, "y": 4},
				
