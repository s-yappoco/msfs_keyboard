				{"label": "SW21",    "matrix": [4, 3], "x": 5, "y": 4},

				{"label": "SW25",    "matrix": [4, 4], "x": 6, "y": 2},
				{"label": "SW26",    "matrix": [5, 4], "x": 6, "y": 3},
				{"label": "SW22",    "matrix": [5, 3], "x": 6, "y": 4},	
				
				{"label": "SW14",    "matrix": [6, 1], "x": 5, "y": 5},
				{"label": "SW18",    "matrix": [6, 2], "x": 6, "y": 5},
				{"label": "SW23",    "matrix": [6, 3], "x": 7, "y": 5},
